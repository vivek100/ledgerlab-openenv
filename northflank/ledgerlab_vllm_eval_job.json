{
    "name":  "ledgerlab-vllm-eval",
    "description":  "Manual H100 vLLM eval job for LedgerLab.",
    "billing":  {
                    "deploymentPlan":  "nf-gpu-hack-16-192-gpu"
                },
    "deployment":  {
                       "region":  "meta-openenv",
                       "external":  {
                                        "registryProvider":  "dockerhub",
                                        "privateImage":  false,
                                        "imagePath":  "nvidia/cuda:12.4.1-runtime-ubuntu22.04"
                                    },
                       "docker":  {
                                      "configType":  "customCommand",
                                      "customCommand":  "bash -lc \u0027set -euo pipefail; export HF_HOME=/workspace/.cache/huggingface; export TRANSFORMERS_CACHE=/workspace/.cache/huggingface; mkdir -p /workspace; cd /workspace; apt-get update \u0026\u0026 apt-get install -y --no-install-recommends ca-certificates git python3 python3-pip curl \u0026\u0026 rm -rf /var/lib/apt/lists/*; rm -rf ledgerlab-openenv; git clone --depth 1 --branch main https://github.com/vivek100/ledgerlab-openenv ledgerlab-openenv; cd ledgerlab-openenv; bash scripts/run_h100_vllm_eval.sh\u0027"
                                  },
                       "storage":  {
                                       "ephemeralStorage":  {
                                                                "storageSize":  61440
                                                            },
                                       "shmSize":  64
                                   },
                       "gpu":  {
                                   "enabled":  true,
                                   "configuration":  {
                                                         "gpuType":  "h100-80",
                                                         "gpuCount":  1
                                                     }
                               }
                   },
    "runtimeEnvironment":  {
                               "WANDB_PROJECT":  "ledgerlab",
                               "WANDB_ENTITY":  "shukla-vivek1993-startup",
                               "BASE_MODEL_SOURCE":  "Qwen/Qwen3-1.7B",
                               "SERVED_MODEL_NAME":  "Qwen/Qwen3-1.7B",
                               "EVAL_SPLIT":  "val",
                               "EVAL_NUM_TASKS":  "12",
                               "EVAL_LOG_TO_WANDB":  "true",
                               "VLLM_GPU_MEMORY_UTILIZATION":  "0.80",
                               "VLLM_MAX_MODEL_LEN":  "4096"
                           },
    "settings":  {
                     "backoffLimit":  0,
                     "activeDeadlineSeconds":  28800
                 },
    "backoffLimit":  0,
    "activeDeadlineSeconds":  28800
}
