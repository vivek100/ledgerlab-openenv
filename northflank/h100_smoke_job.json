{
  "name": "ledgerlab-h100-smoke",
  "description": "Manual H100 smoke job for LedgerLab baseline eval and GRPO startup validation.",
  "billing": {
    "buildPlan": "nf-gpu-hack-16-32-build",
    "deploymentPlan": "nf-gpu-hack-16-64",
    "gpu": {
      "enabled": true,
      "configuration": {
        "gpuType": "h100-80",
        "gpuCount": 1
      }
    }
  },
  "deployment": {
    "region": "meta-openenv",
    "docker": {
      "configType": "customCommand",
      "customCommand": "bash scripts/run_h100_smoke.sh"
    },
    "storage": {
      "ephemeralStorage": {
        "storageSize": 16384
      },
      "shmSize": 1024
    },
    "vcs": {
      "projectUrl": "https://github.com/vivek100/ledgerlab-openenv",
      "projectType": "github",
      "accountLogin": "vivek100",
      "projectBranch": "main"
    }
  },
  "buildConfiguration": {
    "storage": {
      "ephemeralStorage": {
        "storageSize": 16384
      }
    }
  },
  "buildSettings": {
    "storage": {
      "ephemeralStorage": {
        "storageSize": 16384
      }
    },
    "dockerfile": {
      "buildEngine": "kaniko",
      "dockerFilePath": "/Dockerfile.train",
      "dockerWorkDir": "/",
      "useCache": true
    }
  },
  "runtimeEnvironment": {
    "PYTHONUNBUFFERED": "1",
    "HF_HOME": "/workspace/.cache/huggingface",
    "TRANSFORMERS_CACHE": "/workspace/.cache/huggingface"
  },
  "settings": {
    "backoffLimit": 0,
    "runOnSourceChange": "never",
    "activeDeadlineSeconds": 14400
  },
  "backoffLimit": 0,
  "activeDeadlineSeconds": 14400
}
