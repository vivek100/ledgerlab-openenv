FROM python:3.12-slim

ENV PYTHONDONTWRITEBYTECODE=1     PYTHONUNBUFFERED=1     PIP_NO_CACHE_DIR=1     PYTHONPATH=/app     FINBENCH_DATA_PATH=/app/data     FINBENCH_TRACES_DIR=/app/traces     FINBENCH_MAX_STEPS=30     PORT=7860

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends     curl     git     tini     && rm -rf /var/lib/apt/lists/*

RUN python -m pip install --upgrade pip setuptools wheel &&     python -m pip install     "openenv-core[core]>=0.2.1"     "fastapi>=0.115.0"     "pydantic>=2.0.0"     "uvicorn>=0.24.0"     "requests>=2.31.0"     "nbformat>=5.10.0"     "jupyter_client>=8.6.0"     "ipykernel>=6.29.0"     "pandas>=2.2.0"     "openpyxl>=3.1.0"     "datasets>=2.19.0"     "openai>=1.0.0"     "python-dotenv>=1.0.1"

RUN python -m ipykernel install --sys-prefix --name python3

COPY . /app

RUN mkdir -p /app/traces /app/data/_persistent_memory

EXPOSE 7860

HEALTHCHECK --interval=30s --timeout=5s --start-period=15s --retries=3     CMD python -c "import os, urllib.request; urllib.request.urlopen(f'http://localhost:{os.environ.get("PORT", "7860")}/health')" || exit 1

ENTRYPOINT ["/usr/bin/tini", "--"]
CMD ["sh", "-lc", "uvicorn finbench_env.server.app:app --host 0.0.0.0 --port ${PORT:-7860}"]
